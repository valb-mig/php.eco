{
    "name": "valb/eco",
    "description": "A PHP library to handle results, errors and validations.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "result",
        "error",
        "validation",
        "railway",
        "functional"
    ],
    "authors": [
        {
            "name": "valb-mig",
            "email": "valb.mig@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/var-dumper": "^8.0",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "test:coverage": "php -d pcov.enabled=1 ./vendor/bin/phpunit --coverage-html coverage/ --coverage-text",
        "test:coverage-text": "./vendor/bin/phpunit --coverage-text"
    },
    "autoload": {
        "psr-4": {
            "Eco\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eco\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
